{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/demo dev",
    "build": "bun run --cwd packages/obj-diff build",
    "test": "bun run --cwd packages/obj-diff test",
    "ci": "bun run --cwd packages/obj-diff ci",
    "publish-packages": "bun run build && bun run test && bun x changeset version && bun x changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "deep-diff": "^1.0.2",
    "deep-object-diff": "^1.1.9",
    "jsondiffpatch": "^0.7.3",
    "just-diff": "^6.0.2",
    "microdiff": "^1.4.0",
    "recursive-diff": "^1.0.9",
    "tinybench": "^2.8.0"
  }
}
